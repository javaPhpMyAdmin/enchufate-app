# Supabase — copy this file to `.env` and fill in your project values.
# `.env` is gitignored; `.env.example` is the committed template.
#
# Where to find these:
#   - URL:    Supabase Dashboard > Settings > API > Project URL
#   - ANON:   Supabase Dashboard > Settings > API > Project API keys > `anon` `public`
#
# The `anon` key is safe to ship in the client (it's JWT-signed and the
# RLS policies enforce what each user can do). NEVER put the
# `service_role` key here — that one bypasses RLS and belongs only on
# the server.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
