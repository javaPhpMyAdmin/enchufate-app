{
  "expo": {
    "name": "Enchufate",
    "slug": "enchufate-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "enchufate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "developmentClient": false,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6600"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.enchufate.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FF6600"
      },
      "package": "com.enchufate.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Enchufate usa tu ubicación para encontar los cargadores eléctricos mas cercanos a ti."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ede911f7-19d4-4c9c-a5ea-feed32c7ecda"
      }
    },
    "owner": "chelobat16411",
    "updates": {
      "url": "https://u.expo.dev/ede911f7-19d4-4c9c-a5ea-feed32c7ecda"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
